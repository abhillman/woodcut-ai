# Copy to .env and fill in. The classical-CV pipeline runs WITHOUT any key;
# Claude (analysis, prompt-tuning, judge) and the diffusion slot are optional.
ANTHROPIC_API_KEY=

# Default Claude model for analysis + judging. The most capable Opus-tier model.
WOODCUT_CLAUDE_MODEL=claude-opus-4-8

# Diffusion stylization slot. Adapters: stub | replicate | fal
WOODCUT_STYLIZE_ADAPTER=stub
# img2img strength for the diffusion adapters (0..1; lower = closer to the photo)
WOODCUT_STYLIZE_STRENGTH=0.65

# --- Replicate adapter ---
REPLICATE_API_TOKEN=
REPLICATE_MODEL=stability-ai/sdxl

# --- fal.ai adapter (token is bridged to FAL_KEY for the fal client) ---
FAL_AI_TOKEN=
FAL_MODEL=fal-ai/flux/dev/image-to-image
